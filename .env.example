# ============================================================
# 跨境电商项目 - Docker 环境变量
# 复制为 .env 后使用: cp .env.example .env
# ============================================================

# ---------- 通用 ----------
COMPOSE_PROJECT_NAME=cross-border
TZ=Asia/Shanghai

# ---------- 端口映射（宿主机） ----------
NGINX_HTTP_PORT=80
MYSQL_PORT=3306
REDIS_PORT=6379
BACKEND_PORT=3000

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=cross_border

# ---------- Backend (NestJS) ----------
NODE_ENV=development
PORT=3000
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=cross_border
REDIS_HOST=redis
REDIS_PORT=6379
JWT_SECRET=cross-border-jwt-secret-change-me-in-production
JWT_EXPIRES_IN=7d

# ---------- Frontend 构建参数 ----------
VITE_API_BASE_URL=/api
